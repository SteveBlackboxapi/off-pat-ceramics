---
import { site, nav } from '../config';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-name">{site.name}</span>
      <span class="logo-sub">{site.tagline}</span>
    </a>

    <nav class="nav-desktop">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="location">
      {site.location}
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #f8f1e9;
    border-bottom: 1px solid #d4b8a3;
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    text-decoration: none;
    color: inherit;
  }

  .logo-name {
    font-size: 1.45rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .logo-sub {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: #6b6055;
    display: block;
  }

  .nav-desktop {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: inherit;
    text-decoration: none;
  }

  .nav-link.active {
    color: #c26d5d;
  }

  .location {
    font-size: 0.85rem;
    color: #6b6055;
  }
</style>