---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allWorks = await getCollection('works', ({ data }) => !data.draft);
const works = allWorks.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Gallery — Off-Pat Ceramics"
  description="Hand-thrown porcelain and stoneware from Felixstowe"
>
  <section class="gallery-hero section-sm">
    <div class="container">
      <p class="eyebrow fade-up">Work</p>
      <h1 class="gallery-title fade-up fade-up-delay-1">Gallery</h1>
      <p class="gallery-strap fade-up fade-up-delay-2">
        Hand-thrown porcelain & stoneware • made slowly in Felixstowe
      </p>
    </div>
  </section>

  <section class="series section">
    <div class="container">
      <header class="series-header">
        <h2 class="series-title">Recent Work — 2024/2025</h2>
        <p class="series-meta">One-of-a-kind pieces</p>
      </header>

      <div class="works-grid">
        <!-- Your 4 real images -->
        <article class="work-card">
          <div class="work-image">
            <img src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/IMG_5162.jpeg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvSU1HXzUxNjIuanBlZyIsImlhdCI6MTc3OTgwNDI5OCwiZXhwIjoyNzI1ODg0Mjk4fQ.Pf1LTFvRDX4W4LZwDfPLlp5hmEOMmxMjWoTFDpS76M0" 
                 alt="Off-Pat Ceramics piece" loading="lazy" />
          </div>
          <div class="work-info">
            <h3 class="work-title">Recent Bowl</h3>
            <p class="work-meta">Porcelain • 2025</p>
          </div>
        </article>

        <article class="work-card">
          <div class="work-image">
            <img src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/IMG_5201.jpeg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvSU1HXzUyMDEuanBlZyIsImlhdCI6MTc3OTgwNDMzMywiZXhwIjoyNzI1ODg0MzMzfQ.GDI6K_cZhoOwhdIaf8BTe-9i-df3mt8nq459fCGCsok" 
                 alt="Off-Pat Ceramics piece" loading="lazy" />
          </div>
          <div class="work-info">
            <h3 class="work-title">Recent Vessel</h3>
            <p class="work-meta">Stoneware • 2025</p>
          </div>
        </article>

        <article class="work-card">
          <div class="work-image">
            <img src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/IMG_5189.jpeg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvSU1HXzUxODkuanBlZyIsImlhdCI6MTc3OTgwNDM1MiwiZXhwIjoyNzI1ODg0MzUyfQ.ehypOWWhXMzH-fvkHwHFwh8dLF0AxT-fw6BYdGdaLaE" 
                 alt="Off-Pat Ceramics piece" loading="lazy" />
          </div>
          <div class="work-info">
            <h3 class="work-title">Recent Bowl</h3>
            <p class="work-meta">Porcelain • 2025</p>
          </div>
        </article>

        <article class="work-card">
          <div class="work-image">
            <img src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/IMG_5180.jpeg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvSU1HXzUxODAuanBlZyIsImlhdCI6MTc3OTgwNDQwMCwiZXhwIjoyNzI1ODg0NDAwfQ.8mYcmbghC7mxa1WcwZu9cgbE5j6FlzXKG-iFhMP0JaI" 
                 alt="Off-Pat Ceramics piece" loading="lazy" />
          </div>
          <div class="work-info">
            <h3 class="work-title">Recent Piece</h3>
            <p class="work-meta">Stoneware • 2025</p>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-hero {
    text-align: center;
    padding-top: clamp(2.5rem, 6vw, 5rem);
  }
  .gallery-title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-block: 0.5rem;
  }
  .gallery-strap {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 1.05rem;
  }
  .works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 1.5rem;
  }
  @media (min-width: 600px) {
    .works-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2rem;
    }
  }
  .work-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .work-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 2px;
  }
  .work-title {
    font-size: 1.15rem;
    margin: 0.4rem 0 0.2rem;
  }
  .work-meta {
    font-size: 0.85rem;
    color: var(--color-accent);
  }
</style>