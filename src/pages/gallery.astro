---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allWorks = await getCollection('works', ({ data }) => !data.draft);
const works = allWorks.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Gallery — Off-Pat Ceramics"
  description="Hand-thrown porcelain and stoneware from Felixstowe"
>
  <section class="gallery-hero section-sm">
    <div class="container">
      <p class="eyebrow fade-up">Work</p>
      <h1 class="gallery-title fade-up fade-up-delay-1">Gallery</h1>
      <p class="gallery-strap fade-up fade-up-delay-2">
        Hand-thrown porcelain & stoneware • made slowly in Felixstowe
      </p>
    </div>
  </section>

  <section class="series section">
    <div class="container">
      <header class="series-header">
        <h2 class="series-title">Recent Work — 2024/2025</h2>
        <p class="series-meta">One-of-a-kind pieces</p>
      </header>

      <div class="works-grid">
        {works.map((work) => (
          <a href={`/gallery/${work.slug}`} class="work-card">
            <div class="work-image">
              {work.data.image ? (
                <img 
                  src={work.data.image} 
                  alt={work.data.title} 
                  loading="lazy" 
                />
              ) : (
                <div class="placeholder-img" style="aspect-ratio: 4/5;">
                  <span>{work.data.title}</span>
                </div>
              )}
            </div>
            <div class="work-info">
              <h3 class="work-title">{work.data.title}</h3>
              <p class="work-meta">
                {work.data.year} • {work.data.materials}
                {work.data.dimensions && ` • ${work.data.dimensions}`}
              </p>
              {work.data.price && (
                <p class="work-price">{work.data.price}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-hero {
    text-align: center;
    padding-top: clamp(2.5rem, 6vw, 5rem);
  }
  .gallery-title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-block: 0.5rem;
  }
  .gallery-strap {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 1.05rem;
  }
  .works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 1.5rem;
  }
  @media (min-width: 600px) {
    .works-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2rem;
    }
  }
  .work-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }
  .work-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 2px;
    transition: transform 0.4s ease;
  }
  .work-card:hover .work-image img {
    transform: scale(1.03);
  }
  .work-title {
    font-size: 1.15rem;
    margin: 0.4rem 0 0.2rem;
  }
  .work-meta {
    font-size: 0.85rem;
    color: var(--color-accent);
  }
</style>