---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events', ({ data }) => !data.draft);
const upcomingEvents = allEvents
  .filter(e => e.data.date >= new Date())
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={site.name}
  description="Porcelain & Stoneware • Paintings in Clay — Felixstowe"
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-image">
      <img 
        src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/hero-bowl.jpg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvaGVyby1ib3dsLmpwZyIsImlhdCI6MTc3OTc5MTI3NywiZXhwIjoyNzI1ODcxMjc3fQ.8Vv94-evHQq0yImwIVOPx5E9Y2Hlw95eRhHNL5SspWw" 
        alt="Saltglazed pouring bowl, 2024" 
        loading="eager" 
      />
    </div>
  </section>

  <div class="main-content">
    <div class="container">
      <div class="two-column">

        <!-- Upcoming Events -->
        <div class="events-column">
          <h2 class="section-title">Upcoming Events</h2>
          
          {upcomingEvents.length > 0 ? (
            upcomingEvents.map((event, index) => (
              <div class={`event-item ${index < upcomingEvents.length - 1 ? 'event-item-border' : ''}`}>
                <p class="event-date">
                  {event.data.date.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: