---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events', ({ data }) => !data.draft);
const upcomingEvents = allEvents
  .filter(e => e.data.date >= new Date())
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={site.name}
  description="Porcelain & Stoneware • Paintings in Clay — Felixstowe"
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-image">
      <img 
        src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/hero-bowl.jpg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvaGVyby1ib3dsLmpwZyIsImlhdCI6MTc3OTc5MTI3NywiZXhwIjoyNzI1ODcxMjc3fQ.8Vv94-evHQq0yImwIVOPx5E9Y2Hlw95eRhHNL5SspWw" 
        alt="Saltglazed pouring bowl, 2024" 
        loading="eager" 
      />
    </div>
  </section>

  <div class="main-content">
    <div class="container">
      <div class="two-column">

        <!-- Upcoming Events -->
        <div class="events-column">
          <h2 class="section-title">Upcoming Events</h2>
          
          {upcomingEvents.length > 0 ? (
            upcomingEvents.map((event, index) => (
              <div class={`event-item ${index < upcomingEvents.length - 1 ? 'event-item-border' : ''}`}>
                <p class="event-date">
                  {event.data.date.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' })}
                </p>
                <p class="event-title">{event.data.title}</p>
                <p class="event-info">
                  {event.data.time} • {event.data.location}
                </p>
                {event.data.spotsLeft && (
                  <p class="spots">{event.data.spotsLeft} spots left</p>
                )}
              </div>
            ))
          ) : (
            <p>No upcoming events at the moment.</p>
          )}
        </div>

        <!-- The Studio -->
        <div class="studio-column">
          <h2 class="section-title">The Studio</h2>
          <div class="studio-info">
            <p><strong>Off-Pat Ceramics</strong><br />
            Felixstowe, Suffolk</p>
            
            <p>
              Studio visits by appointment only.<br />
              Please get in touch to arrange a visit.
            </p>
            
            <p>
              <a href={`mailto:${site.email}`}>{site.email}</a><br />
              {site.phone && <a href={`tel:${site.phone}`}>{site.phone}</a>}
            </p>

            <p class="studio-address">
              3 Penfold Road<br />
              Felixstowe, Suffolk<br />
              IP11 7BP
            </p>

            <div class="studio-map">
              <img 
                src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/map.jpg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvbWFwLmpwZyIsImlhdCI6MTc3OTc5Mjg2MywiZXhwIjozMDQxMjMyODYzfQ.f1FH3w0ILKwAEP2g26iEb38LcBvDARZAfBRG3LBwMgE" 
                alt="Map to Off-Pat Ceramics studio" 
                loading="lazy"
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    height: 75vh;
    min-height: 580px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #f8f1e9;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-content {
    padding: 5rem 0 6rem;
    background: var(--color-bg);
  }

  .two-column {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 900px) {
    .two-column {
      grid-template-columns: 1fr 1fr;
      gap: 7rem;
    }
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    color: var(--color-text);
  }

  .event-item {
    margin-bottom: 2.25rem;
  }

  .event-item-border {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-line);
  }

  .event-date {
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .event-title {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .event-info {
    color: #6b6055;
    margin-bottom: 0.3rem;
  }

  .spots {
    color: #c26d5d;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .studio-map {
    margin-top: 2rem;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    max-width: 380px;
  }

  .studio-map img {
    width: 100%;
    height: auto;
    display: block;
  }

  .studio-address {
    margin: 1.2rem 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>