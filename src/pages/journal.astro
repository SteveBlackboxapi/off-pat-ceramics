---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Journal — Off-Pat Ceramics"
  description="Notes from the studio — inspiration, process, and the work behind the work."
>
  <section class="journal-hero section-sm">
    <div class="container">
      <p class="eyebrow">Notes from the studio</p>
      <h1>Journal</h1>
    </div>
  </section>

  <section class="journal-list section">
    <div class="container container-narrow">
      <ul class="post-list">
        {posts.map((post, i) => (
          <li class={`post-row ${i % 2 === 0 ? 'post-row-left' : 'post-row-right'}`}>
            <a href={`/journal/${post.slug}`} class="post-link">
              <div class="post-image">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                ) : (
                  <div class="placeholder-img" style="aspect-ratio: 4/3;">
                    <span>{post.data.title}</span>
                  </div>
                )}
              </div>
              <div class="post-meta">
                <time datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                <h2 class="post-title">{post.data.title}</h2>
                {post.data.subtitle && <p class="post-subtitle">{post.data.subtitle}</p>}
                <p class="post-excerpt">{post.data.excerpt}</p>
                <span class="post-read">Read entry →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .journal-hero { 
    text-align: center; 
    padding-top: clamp(3rem, 8vw, 6rem); 
  }
  .journal-hero h1 { 
    font-size: clamp(3rem, 8vw, 6rem); 
    margin-top: 0.5rem;
    font-variation-settings: 'opsz' 144, 'SOFT' 20, 'wght' 350;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(3.5rem, 7vw, 6rem);
  }

  .post-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }

  .post-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 3px;
    transition: transform 0.4s ease;
  }

  .post-link:hover .post-image img {
    transform: scale(1.02);
  }

  .post-meta time {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.15;
    margin: 0.6rem 0 0.8rem;
  }

  .post-excerpt {
    line-height: 1.75;
    color: var(--color-text);
    max-width: 60ch;
  }

  .post-read {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  @media (min-width: 800px) {
    .post-link { 
      grid-template-columns: 1.1fr 1fr; 
      gap: 3.5rem; 
    }
  }
</style>