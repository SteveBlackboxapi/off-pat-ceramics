---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config';
---

<BaseLayout
  title={`Contact — ${site.name}`}
  description="Commissions, studio visits, and quiet conversations about clay and coast."
>
  <section class="contact section">
    <div class="container">
      <div class="contact-grid">
        <!-- Your real studio image -->
        <div class="contact-image">
          <img 
            src="https://fgxfkyzvkpgrsphgjgxf.supabase.co/storage/v1/object/sign/images/IMG_5175.jpeg?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV9hNTI2OGMwYy02NjVlLTQ4YTEtODFlYy0zYTcwY2YwZjdiZDIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJpbWFnZXMvSU1HXzUxNzUuanBlZyIsImlhdCI6MTc3OTgwMzk4NCwiZXhwIjoyNzI1ODgzOTg0fQ.N4Aga5idbIc94tiRHELEznFCax5yAVJagihHa8SP5B8" 
            alt="Off-Pat Ceramics Studio" 
            loading="lazy"
          />
        </div>

        <div class="contact-content">
          <h1>Let's make something together.</h1>
          <p class="lead">
            I welcome commissions, studio visits (limited), and quiet
            conversations about clay and coast.
          </p>

          <form
            class="contact-form"
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hp" hidden>
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <label class="field">
              <span class="field-label">Your name</span>
              <input name="name" type="text" required autocomplete="name" />
            </label>

            <label class="field">
              <span class="field-label">Email address</span>
              <input name="email" type="email" required autocomplete="email" />
            </label>

            <label class="field">
              <span class="field-label">Subject</span>
              <select name="subject" required>
                <option value="">Select an option</option>
                <option>Commission Enquiry</option>
                <option>Studio Visit</option>
                <option>Stockist Enquiry</option>
                <option>Workshop / Event</option>
                <option>Other</option>
              </select>
            </label>

            <label class="field">
              <span class="field-label">Message</span>
              <textarea name="message" rows="6" required></textarea>
            </label>

            <button type="submit" class="btn btn-filled">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-image img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 2px;
  }

  .contact-content h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    max-width: 14ch;
  }

  .lead {
    max-width: 44ch;
    font-size: 1.1rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .field input,
  .field select,
  .field textarea {
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-accent);
    background: transparent;
    border-radius: 2px;
  }

  @media (min-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr 1.15fr;
      gap: 4rem;
    }
  }
</style>