---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'journal'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`${post.data.title} — Journal`}
  description={post.data.excerpt}
  ogImage={post.data.image}
>
  <article class="post section">
    <div class="container container-narrow">
      <header class="post-header fade-up">
        <p class="back-link"><a href="/journal" class="link-underline">← Back to Journal</a></p>
        <time datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <h1>{post.data.title}</h1>
        {post.data.subtitle && <p class="post-subtitle">{post.data.subtitle}</p>}
      </header>

      {post.data.image && (
        <figure class="post-image fade-up fade-up-delay-1">
          <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} />
        </figure>
      )}

      <div class="post-body fade-up fade-up-delay-2">
        <Content />
      </div>

      {post.data.tags.length > 0 && (
        <footer class="post-footer">
          <ul class="post-tags">
            {post.data.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        </footer>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .back-link {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .post-header time {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .post-header h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    max-width: 22ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 380;
  }

  .post-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 1.2rem;
    max-width: 40ch;
  }

  .post-image {
    margin: 0 0 3rem 0;
  }

  .post-image img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .post-body {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--color-text);
    max-width: 65ch;
    margin: 0 auto;
  }

  .post-body :global(h2) {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-variation-settings: 'opsz' 36, 'SOFT' 30, 'wght' 380;
  }

  .post-body :global(h3) {
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    border-bottom: 1px solid currentColor;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text-muted);
  }

  .post-body :global(img) {
    margin: 2rem 0;
    width: 100%;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
    text-align: center;
  }

  .post-tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
  }

  .post-tags li {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
  }
</style>
