---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — Your Studio">
  <section class="section">
    <div class="container" style="text-align: center; padding-block: 6rem;">
      <p class="eyebrow">404</p>
      <h1 style="font-size: clamp(3rem, 8vw, 5.5rem); margin: 1rem 0;">
        This page has wandered off.
      </h1>
      <p class="lead" style="max-width: 40ch; margin: 0 auto 2rem;">
        It might have gone down to the shore. While you wait, you could
        have a look at the gallery, or read something from the journal.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn">Back to Events</a>
        <a href="/gallery" class="btn">View Gallery</a>
      </div>
    </div>
  </section>
</BaseLayout>
